# TikHub API key — pick one method:
# 1) export TIKHUB_API_KEY=your_key
# 2) echo your_key > ~/.config/tikhub/key
# Register (ref YS1mhMDA): https://user.tikhub.io/register?ref=YS1mhMDA

# Path to social-ecom-decoder (douyin-pulse CLI)
SOCIAL_ECOM_DECODER=~/.claude/skills/social-ecom-decoder

# Shown in report metadata (optional)
REPORT_AUTHORS=Your Team

# Output HTML filename (relative to project root)
REPORT_HTML=monthly-report.html

# Optional: custom SKU brief JSON directory
# BRIEF_CATALOG_DIR=./templates/brief
